# ===== 必須設定 =====
# Botトークン（Discord Developer Portal で取得）
DISCORD_TOKEN=
# 対象サーバー（ギルド）ID（任意・後方互換用）
# 未指定でも動作します（マルチテナントモード: 参加中の全サーバーで独立動作）。
# 既存の単一サーバー運用では従来どおり指定してください
# （DB マイグレーション時のバックフィル値としても使われます）。
GUILD_ID=

# 暗号鍵（Todoist トークンの暗号化保存に必須）
# 生成方法:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ※ この鍵を紛失すると保存済みトークンを復号できなくなります
#   （その場合は各サーバーで /todoist-setup を再実行してください）
ENCRYPTION_KEY=

# ===== データベース =====
# ローカル開発・テスト用: SQLite のパス（デフォルト: ./data/club.db）
DB_PATH=./data/club.db
# 本番（NocoDB 構成）用: PostgreSQL 接続 URL。
# 設定すると PostgreSQL に接続し、DB_PATH の SQLite は使いません。
# DATABASE_URL=postgresql://clubbot:パスワード@127.0.0.1:5432/clubdb

# ===== 共通 =====
# タイムゾーン（デフォルト: Asia/Tokyo）
TZ=Asia/Tokyo

# 注: Google Sheets 連携は廃止されました（NocoDB 移行）。
#     旧 Sheets からのデータ移行に必要な環境変数（GOOGLE_CREDENTIALS_PATH,
#     SPREADSHEET_ID 等）は scripts/migrate_sheets_to_db.py の実行時のみ
#     設定します（docs/NOCODB.md 参照）。
# 注: Todoist の API トークンは .env には書きません。
#     セキュリティのため、Discord 上で各サーバーの管理者が
#     /todoist-setup を実行し、表示されるフォーム（Modal）から登録します
#     （暗号化して DB に保存）。
# 注: その他の設定（チャンネルID、ロールIDなど）もボットコマンドで設定できます
#     （/settings_set /set_channel /set_role など）。

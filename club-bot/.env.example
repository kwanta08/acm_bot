# ===== 必須設定 =====
# Botトークン（Discord Developer Portal で取得）
DISCORD_TOKEN=
# 対象サーバー（ギルド）ID
GUILD_ID=

# ===== 共通 =====
# タイムゾーン（デフォルト: Asia/Tokyo）
TZ=Asia/Tokyo
# SQLite データベースのパス（デフォルト: ./data/club.db）
DB_PATH=./data/club.db

# ===== 外部サービス（任意） =====
# Todoist API トークン（Todoist 設定 > インテグレーション で取得）
TODOIST_API_TOKEN=
# Google サービスアカウント JSON キーのパス
GOOGLE_CREDENTIALS_PATH=./credentials.json

# 注: その他の設定（チャンネルID、ロールIDなど）はボットコマンドで設定できます
# /settings コマンドを使用してカスタマイズしてください

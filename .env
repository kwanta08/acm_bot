# ===== Discord =====
# Bot トークン（Discord Developer Portal で取得）
DISCORD_TOKEN=
# 対象サーバー（ギルド）ID。スラッシュコマンドの即時同期に使用
GUILD_ID=

# ===== 通知先チャンネル ID =====
# Bot のログ・障害通知を投稿するチャンネル
BOT_LOG_CHANNEL_ID=
# 全体連絡（既定の告知先）
DEFAULT_ANNOUNCE_CHANNEL_ID=
# 日程調整・出欠投票の既定投稿先
DEFAULT_SCHEDULE_CHANNEL_ID=
# 部会まとめ・週次自動投稿の投稿先
DEFAULT_PROGRESS_CHANNEL_ID=
# タスク通知（期限・超過）の投稿先
DEFAULT_TASK_CHANNEL_ID=

# ===== ロール ID（権限判定）=====
# 幹部（L3）ロール ID
EXEC_ROLE_ID=
# Bot 管理者（L4）ロール ID
ADMIN_ROLE_ID=
# 班長（L2）ロール ID（カンマ区切りで複数可。班ごとの班長ロールを並べる）
LEADER_ROLE_IDS=

# ===== Todoist =====
# Todoist API トークン（Todoist 設定 > インテグレーション で取得）
TODOIST_API_TOKEN=
# 既定プロジェクト ID（タスク作成先）
TODOIST_PROJECT_ID=
# 「今日やること」ラベル名
TODAY_LABEL_NAME=今日やること
# 「今日やること」通知の投稿先チャンネル（未指定時は DEFAULT_TASK_CHANNEL_ID）
TODAY_LABEL_CHANNEL_ID=

# ===== Google Sheets =====
# サービスアカウント JSON キーのパス
GOOGLE_CREDENTIALS_PATH=./credentials.json
# 運営台帳用スプレッドシート ID
SPREADSHEET_ID=
# 各シート名（既定値のままで可）
SHEET_TASKS=tasks
SHEET_ATTENDANCE=attendance
SHEET_MEMBERS=members
SHEET_TEAM_SUMMARY=team_summary
SHEET_AUDIT_LOG=audit_log
# 桁巻き記録用ブック ID（SPREADSHEET_ID と同一ブックでも可。空なら SPREADSHEET_ID を流用）
LAYER_SPREADSHEET_ID=

# ===== 共通 =====
# タイムゾーン
TZ=Asia/Tokyo
# SQLite データベースのパス
DB_PATH=./data/club.db
